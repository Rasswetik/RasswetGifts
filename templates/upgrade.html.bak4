<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Rasswet — Апгрейд</title>
<link rel="icon" href="/static/img/logo.png" type="image/png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--bg:#0d1117;--card:#161b22;--text:#fff;--text2:rgba(255,255,255,.5);--blue:#2563eb;--green:#1EE44C;--red:#F96999;--safe-bottom:env(safe-area-inset-bottom,0px)}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}

.top-bar{display:flex;justify-content:space-between;align-items:center;padding:12px 16px}
.top-left{display:flex;align-items:center;gap:10px}
.top-avatar{width:32px;height:32px;border-radius:50%;object-fit:cover}
.top-nick{font-size:14px;font-weight:600}
.top-right-btns{display:flex;gap:8px;align-items:center}
.bal-pill{display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:20px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);font-weight:600;font-size:13px}
.bal-pill img{width:16px;height:16px}
.bal-plus{width:26px;height:26px;border-radius:50%;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);color:#fff;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center}

.upgrade-wrap{max-width:480px;margin:0 auto;padding:0 16px 100px;display:flex;flex-direction:column;align-items:center;gap:12px}
.page-title{font-size:20px;font-weight:800;padding:8px 0}

/* WHEEL */
.wheel-section{padding:16px 0 12px;display:flex;flex-direction:column;align-items:center}
.wheel-container{position:relative;width:220px;height:220px}
.wheel-svg{position:absolute;inset:0;width:100%;height:100%}
.wheel-green-zone{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}
.wheel-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:76px;height:76px;border-radius:50%;background:#0d1117;border:2px solid #2a3544;display:flex;align-items:center;justify-content:center;z-index:5}
.wheel-center img{width:50px;height:50px;object-fit:contain;display:none}
.chance-pct{font-size:18px;font-weight:800;color:var(--text2)}
.wheel-center.flash-green{animation:flashG .4s ease 3}
.wheel-center.flash-red{animation:flashR .4s ease 3}
@keyframes flashG{50%{border-color:var(--green);box-shadow:0 0 20px rgba(30,228,76,.5)}}
@keyframes flashR{50%{border-color:var(--red);box-shadow:0 0 20px rgba(249,105,153,.5)}}
.wheel-result-icon{display:none;width:36px;height:36px}
.wheel-result-icon.show{display:block}

/* Pointer */
.wheel-pointer-wrap{position:absolute;top:50%;left:50%;width:0;height:0;z-index:10}
.wheel-pointer{position:absolute;left:50%;bottom:0;transform:translateX(-50%) translateY(-90px);width:14px;height:20px}
.wheel-pointer img{width:100%;height:100%}

.wheel-glow{position:absolute;inset:0;border-radius:50%;pointer-events:none;opacity:0;transition:opacity .3s}
.wheel-glow.spinning{opacity:1;animation:glowPulse 1s infinite}
@keyframes glowPulse{0%,100%{box-shadow:0 0 20px rgba(245,158,11,.2)}50%{box-shadow:0 0 40px rgba(245,158,11,.4)}}

/* UPGRADE BTN */
.upgrade-btn{width:100%;height:50px;border-radius:14px;border:none;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;font-family:'Inter',sans-serif;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 16px rgba(37,99,235,.3)}
.upgrade-btn:disabled{background:#1f2937;color:rgba(255,255,255,.3);cursor:not-allowed;box-shadow:none}
.upgrade-btn.win{background:linear-gradient(135deg,#059669,var(--green))!important}
.upgrade-btn.fail{background:linear-gradient(135deg,#dc2626,var(--red))!important}

/* CARDS */
.cards-row{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px}
.card{background:rgba(22,27,34,.8);border:1.5px dashed rgba(255,255,255,.1);border-radius:16px;padding:28px 12px 24px;display:flex;flex-direction:column;align-items:center;min-height:150px;justify-content:center;cursor:pointer}
.card.has-gift{border-style:solid;border-color:rgba(59,130,246,.3);background:rgba(59,130,246,.05)}
.card-placeholder{display:flex;flex-direction:column;align-items:center;gap:12px}
.card-icon svg{width:44px;height:44px;stroke:rgba(255,255,255,.25);stroke-width:1.2;fill:none}
.card-text{font-size:13px;font-weight:500;color:rgba(255,255,255,.4);text-align:center;line-height:1.3}
.gift-preview{display:none;flex-direction:column;align-items:center;gap:6px}
.card.has-gift .gift-preview{display:flex}
.card.has-gift .card-placeholder{display:none}
.gift-preview img{width:64px;height:64px;object-fit:contain}
.gift-preview-name{font-size:11px;font-weight:600;color:#fff;text-align:center;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.gift-preview-value{font-size:10px;color:var(--text2);display:flex;align-items:center;gap:3px}
.gift-preview-value img{width:10px;height:10px}

/* BUTTONS */
.btns-row{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:10px}
.select-btn{height:44px;border-radius:12px;border:none;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer}
.select-btn:first-child{background:linear-gradient(135deg,#1e3a5f,#1e40af);color:#fff}
.select-btn:last-child{background:rgba(255,255,255,.08);color:rgba(255,255,255,.7)}

/* EMPTY STATE */
.empty-state{width:100%;padding:40px 16px 20px;display:flex;flex-direction:column;align-items:center;gap:6px}
.empty-state-title{font-size:18px;font-weight:800}
.empty-state-text{font-size:14px;color:rgba(255,255,255,.45)}
.empty-state-btn{margin-top:14px;padding:12px 28px;border-radius:12px;border:none;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer}

/* PICKER */
.picker-overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:5000;display:flex;align-items:flex-end;justify-content:center;opacity:0;visibility:hidden;backdrop-filter:blur(10px);transition:opacity .3s,visibility .3s}
.picker-overlay.show{opacity:1;visibility:visible}
.picker-modal{background:linear-gradient(180deg,#1E2538,#151B2D);border-radius:24px 24px 0 0;width:100%;max-width:480px;max-height:75vh;padding:20px 16px calc(20px + var(--safe-bottom));transform:translateY(100%);transition:transform .35s;display:flex;flex-direction:column}
.picker-overlay.show .picker-modal{transform:translateY(0)}
.picker-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.picker-title{font-size:16px;font-weight:800}
.picker-close{width:32px;height:32px;border-radius:10px;border:none;background:rgba(249,105,153,.1);cursor:pointer;display:flex;align-items:center;justify-content:center}
.picker-close svg{width:14px;height:14px;stroke:var(--red);stroke-width:2.5;fill:none}
.picker-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;overflow-y:auto;flex:1}
.picker-item{border-radius:16px;border:1px solid rgba(255,255,255,.05);background:rgba(255,255,255,.02);display:flex;flex-direction:column;align-items:center;cursor:pointer;padding:10px 6px 8px}
.picker-item.selected{border-color:var(--blue);background:rgba(59,130,246,.08)}
.picker-item img{width:68px;height:68px;object-fit:contain;margin-bottom:6px}
.picker-item-name{font-size:10px;font-weight:600;color:var(--text2)}
.picker-item-value{font-size:11px;font-weight:700;margin-top:2px}

/* TARGET PICKER */
.target-picker-overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:5000;display:flex;align-items:flex-end;justify-content:center;opacity:0;visibility:hidden;backdrop-filter:blur(10px);transition:opacity .3s,visibility .3s}
.target-picker-overlay.show{opacity:1;visibility:visible}
.target-picker-modal{background:linear-gradient(180deg,#1E2538,#151B2D);border-radius:24px 24px 0 0;width:100%;max-width:480px;max-height:75vh;padding:20px 16px calc(20px + var(--safe-bottom));transform:translateY(100%);transition:transform .35s;display:flex;flex-direction:column}
.target-picker-overlay.show .target-picker-modal{transform:translateY(0)}
.target-list{display:flex;flex-direction:column;gap:6px;overflow-y:auto;flex:1}
.target-item{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:14px;border:1px solid rgba(255,255,255,.05);background:rgba(255,255,255,.02);cursor:pointer}
.target-item img{width:44px;height:44px;object-fit:contain}
.target-item-info{flex:1;min-width:0}
.target-item-name{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.target-item-price{font-size:12px;color:var(--text2);display:flex;align-items:center;gap:4px}
.target-item-price img{width:12px;height:12px}
.target-item-chance{font-size:13px;font-weight:800;color:var(--green)}

/* DEPOSIT */
.deposit-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:5650;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;backdrop-filter:blur(8px);transition:opacity .3s,visibility .3s}
.deposit-overlay.show{opacity:1;visibility:visible}
.deposit-modal{background:linear-gradient(180deg,#1E2538,#151B2D);border-radius:24px;width:90%;max-width:360px;padding:24px 20px;transform:scale(.9);transition:transform .3s}
.deposit-overlay.show .deposit-modal{transform:scale(1)}
.deposit-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.deposit-title{font-weight:800;font-size:18px}
.deposit-close{width:32px;height:32px;border-radius:10px;border:none;background:rgba(249,105,153,.1);cursor:pointer;display:flex;align-items:center;justify-content:center}
.deposit-close svg{width:14px;height:14px;stroke:var(--red);fill:none;stroke-width:2}
.deposit-methods{display:flex;gap:10px}
.deposit-method-btn{flex:1;padding:16px 10px;border-radius:16px;border:1px solid rgba(255,255,255,.05);background:rgba(255,255,255,.03);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:8px}
.deposit-method-btn img{width:36px;height:36px}
.deposit-method-btn span{font-weight:700;font-size:13px;color:#fff}
.confetti-canvas{position:fixed;inset:0;z-index:6001;pointer-events:none}

/* BOTTOM NAV */
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);z-index:100;width:100%;max-width:480px;height:72px;padding:0 8px calc(var(--safe-bottom) + 8px);background:rgba(13,17,23,.95);backdrop-filter:blur(20px);border-top:1px solid rgba(255,255,255,.05);display:flex;align-items:center;justify-content:space-around}
.bnav-item{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 16px;border-radius:12px;color:rgba(255,255,255,.4);font-weight:600;text-decoration:none}
.bnav-item svg{width:24px;height:24px;stroke:currentColor;fill:none}
.bnav-item span{font-size:10px}
.bnav-item.active{background:rgba(255,255,255,.08);color:#fff}
</style>
</head>
<body>

<div class="top-bar">
    <div class="top-left">
        <img class="top-avatar" id="topAvatar" src="/static/img/default_avatar.png" alt="">
        <span class="top-nick" id="topNick">—</span>
    </div>
    <div class="top-right-btns">
        <div class="bal-pill"><img src="/static/img/ton.png" alt=""><span id="balVal">0.00</span></div>
        <button class="bal-plus" onclick="openDeposit()">+</button>
    </div>
</div>

<div class="upgrade-wrap">
    <div class="page-title">Апгрейд</div>

    <!-- WHEEL -->
    <div class="wheel-section">
        <div class="wheel-container">
            <div class="wheel-glow" id="wheelGlow"></div>
            <!-- Wheel SVG inline -->
            <svg class="wheel-bg" viewBox="0 0 200 200">
                <defs>
                    <linearGradient id="orangeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#f59e0b"/>
                        <stop offset="50%" stop-color="#ea580c"/>
                        <stop offset="100%" stop-color="#dc2626"/>
                    </linearGradient>
                </defs>
                <circle cx="100" cy="100" r="96" fill="none" stroke="url(#orangeGrad)" stroke-width="3"/>
                <circle cx="100" cy="100" r="88" fill="none" stroke="rgba(100,120,150,0.15)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="78" fill="none" stroke="rgba(100,120,150,0.12)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="68" fill="none" stroke="rgba(100,120,150,0.1)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="58" fill="none" stroke="rgba(100,120,150,0.08)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="48" fill="none" stroke="rgba(100,120,150,0.06)" stroke-width="1.5"/>
            </svg>
            
            <!-- Pointer wrap for rotation -->
            <div class="wheel-pointer-wrap" id="pointerWrap">
                <div class="wheel-pointer">
                    <svg viewBox="0 0 24 32" fill="none">
                        <defs>
                            <linearGradient id="pGrad" x1="12" y1="0" x2="12" y2="32" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#f59e0b"/>
                                <stop offset="1" stop-color="#ea580c"/>
                            </linearGradient>
                            <filter id="pGlow" x="-50%" y="-50%" width="200%" height="200%">
                                <feGaussianBlur stdDeviation="2" result="blur"/>
                                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                            </filter>
                        </defs>
                        <path d="M12 0L16 10H8L12 0Z" fill="url(#pGrad)" filter="url(#pGlow)"/>
                        <circle cx="12" cy="14" r="5" fill="url(#pGrad)" filter="url(#pGlow)"/>
                    </svg>
                </div>
            </div>
            
            <div class="wheel-center" id="wheelCenter">
                <img id="wheelCenterImg" src="" alt="">
                <span class="chance-pct" id="chancePct">0.00%</span>
                <svg class="wheel-result-icon" id="resultSad" viewBox="0 0 60 60"><circle cx="30" cy="30" r="28" fill="none" stroke="#F96999" stroke-width="2"/><circle cx="20" cy="24" r="2.5" fill="#F96999"/><circle cx="40" cy="24" r="2.5" fill="#F96999"/><path d="M20 42c4-6 16-6 20 0" fill="none" stroke="#F96999" stroke-width="2" stroke-linecap="round"/></svg>
                <svg class="wheel-result-icon" id="resultHappy" viewBox="0 0 60 60"><circle cx="30" cy="30" r="28" fill="none" stroke="#1EE44C" stroke-width="2"/><circle cx="20" cy="24" r="2.5" fill="#1EE44C"/><circle cx="40" cy="24" r="2.5" fill="#1EE44C"/><path d="M20 38c4 6 16 6 20 0" fill="none" stroke="#1EE44C" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
        </div>
    </div>

    <!-- UPGRADE BUTTON -->
    <button class="upgrade-btn" id="upgradeBtn" disabled onclick="doUpgrade()">
        <span id="upgradeBtnText">Апгрейд</span>
    </button>

    <!-- CARDS -->
    <div class="cards-row">
        <div class="card" id="leftCard" onclick="openGiftPicker()">
            <div class="card-placeholder">
                <div class="card-icon">
                    <svg viewBox="0 0 48 48" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="6" y="22" width="36" height="20" rx="2"/>
                        <rect x="4" y="16" width="40" height="8" rx="2"/>
                        <path d="M24 16v26"/>
                        <path d="M24 16c-3-4-9-6-9 0h9"/>
                        <path d="M24 16c3-4 9-6 9 0h-9"/>
                    </svg>
                </div>
                <div class="card-text">Выберите ваш<br>подарок</div>
            </div>
            <div class="gift-preview">
                <img id="leftGiftImg" src="" alt="">
                <div class="gift-preview-name" id="leftGiftName"></div>
                <div class="gift-preview-value"><img src="/static/img/ton.png" alt=""><span id="leftGiftValue"></span></div>
            </div>
        </div>
        <div class="card" id="rightCard" onclick="openTargetPicker()">
            <div class="card-placeholder">
                <div class="card-icon">
                    <svg viewBox="0 0 48 48" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="6" y="22" width="36" height="20" rx="2"/>
                        <rect x="4" y="16" width="40" height="8" rx="2"/>
                        <path d="M24 16v26"/>
                        <path d="M24 16c-3-4-9-6-9 0h9"/>
                        <path d="M24 16c3-4 9-6 9 0h-9"/>
                    </svg>
                </div>
                <div class="card-text">Выберите желаемый<br>подарок</div>
            </div>
            <div class="gift-preview">
                <img id="rightGiftImg" src="" alt="">
                <div class="gift-preview-name" id="rightGiftName"></div>
                <div class="gift-preview-value"><img src="/static/img/ton.png" alt=""><span id="rightGiftValue"></span></div>
            </div>
        </div>
    </div>

    <!-- BUTTONS -->
    <div class="btns-row">
        <button class="select-btn" onclick="openGiftPicker()">Инвентарь</button>
        <button class="select-btn" onclick="openTargetPicker()">Желаемый</button>
    </div>

    <!-- EMPTY STATE -->
    <div class="empty-state" id="emptyState">
        <div class="empty-state-title">Нет подарков</div>
        <div class="empty-state-text">Начните открывать кейсы</div>
        <button class="empty-state-btn" onclick="window.location.href='/'">К кейсам</button>
    </div>
</div>

<!-- GIFT PICKER -->
<div class="picker-overlay" id="giftPickerOverlay" onclick="if(event.target===this)closeGiftPicker()">
    <div class="picker-modal">
        <div class="picker-header">
            <div class="picker-title">Выбери подарок</div>
            <button class="picker-close" onclick="closeGiftPicker()"><svg viewBox="0 0 14 14"><line x1="3" y1="3" x2="11" y2="11"/><line x1="11" y1="3" x2="3" y2="11"/></svg></button>
        </div>
        <div class="picker-grid" id="giftPickerGrid"></div>
    </div>
</div>

<!-- TARGET PICKER -->
<div class="target-picker-overlay" id="targetPickerOverlay" onclick="if(event.target===this)closeTargetPicker()">
    <div class="target-picker-modal">
        <div class="picker-header">
            <div class="picker-title">Выбери цель</div>
            <button class="picker-close" onclick="closeTargetPicker()"><svg viewBox="0 0 14 14"><line x1="3" y1="3" x2="11" y2="11"/><line x1="11" y1="3" x2="3" y2="11"/></svg></button>
        </div>
        <div class="target-list" id="targetList"></div>
    </div>
</div>

<!-- DEPOSIT -->
<div class="deposit-overlay" id="depositOverlay" onclick="if(event.target===this)closeDeposit()">
    <div class="deposit-modal">
        <div class="deposit-header">
            <div class="deposit-title">Пополнение</div>
            <button class="deposit-close" onclick="closeDeposit()"><svg viewBox="0 0 14 14"><line x1="3" y1="3" x2="11" y2="11"/><line x1="11" y1="3" x2="3" y2="11"/></svg></button>
        </div>
        <div class="deposit-methods">
            <button class="deposit-method-btn" onclick="closeDeposit();window.location.href='/crash'"><img src="/static/img/ton.png" alt="TON"><span>TON</span></button>
            <button class="deposit-method-btn" onclick="closeDeposit();window.location.href='/crash'"><img src="/static/img/star.png" alt="Stars"><span>Stars</span></button>
        </div>
    </div>
</div>

<canvas class="confetti-canvas" id="confettiCanvas"></canvas>

<nav class="bottom-nav">
    <a class="bnav-item" href="/games">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="3"/><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="18" cy="12" r="1" fill="currentColor" stroke="none"/></svg>
        <span>Игры</span>
    </a>
    <a class="bnav-item" href="/news">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
        <span>Новости</span>
    </a>
    <a class="bnav-item" href="/leaderboard">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>
        <span>Топ</span>
    </a>
    <a class="bnav-item" href="/inventory">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Профиль</span>
    </a>
</nav>

<script>
var tg=window.Telegram&&Telegram.WebApp;
var userId=null;
if(tg){tg.ready();tg.expand();tg.setHeaderColor('#0d1117');tg.setBackgroundColor('#0d1117');if(tg.initDataUnsafe&&tg.initDataUnsafe.user)userId=tg.initDataUnsafe.user.id;}

var userInventory=[];
var selectedGift=null;
var targetGift=null;
var possibleTargets=[];
var isSpinning=false;

async function loadTopBar(){
    if(!userId)return;
    try{
        var r=await fetch('/api/user/'+userId);var d=await r.json();
        if(d.success&&d.user){
            var u=d.user;
            document.getElementById('topNick').textContent=u.first_name||u.username||'User';
            if(u.photo_url)document.getElementById('topAvatar').src=u.photo_url;
            document.getElementById('balVal').textContent=((u.balance_stars||0)/100).toFixed(2);
        }
    }catch(e){}
}

async function loadInventory(){
    if(!userId)return;
    try{
        var r=await fetch('/api/inventory/'+userId);var d=await r.json();
        if(d.success){
            userInventory=d.inventory.filter(function(it){return !it.is_withdrawing&&!it.challenge_locked});
            updateEmptyState();
        }
    }catch(e){}
}

function updateEmptyState(){
    document.getElementById('emptyState').style.display=userInventory.length===0?'flex':'none';
}

function openGiftPicker(){
    if(isSpinning)return;
    var grid=document.getElementById('giftPickerGrid');grid.innerHTML='';
    if(userInventory.length===0){
        grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:30px;color:rgba(255,255,255,.4)">Нет подарков в инвентаре</div>';
    }else{
        userInventory.forEach(function(it){
            var isSelected=selectedGift&&selectedGift.id===it.id;
            var div=document.createElement('div');
            div.className='picker-item'+(isSelected?' selected':'');
            div.innerHTML='<img src="'+it.gift_image+'" alt=""><div class="picker-item-name">'+it.gift_name+'</div><div class="picker-item-value">'+((it.gift_value||0)/100).toFixed(2)+'</div>';
            div.onclick=function(){selectGift(it);closeGiftPicker();};
            grid.appendChild(div);
        });
    }
    document.getElementById('giftPickerOverlay').classList.add('show');
}
function closeGiftPicker(){document.getElementById('giftPickerOverlay').classList.remove('show')}

function selectGift(g){
    selectedGift={id:g.id,name:g.gift_name,image:g.gift_image,value:g.gift_value,gift_id:g.gift_id};
    document.getElementById('leftCard').classList.add('has-gift');
    document.getElementById('leftGiftImg').src=g.gift_image;
    document.getElementById('leftGiftName').textContent=g.gift_name;
    document.getElementById('leftGiftValue').textContent=((g.gift_value||0)/100).toFixed(2);
    if(targetGift)resetTarget();
    updateWheel();
}

function resetTarget(){
    targetGift=null;
    document.getElementById('rightCard').classList.remove('has-gift');
    document.getElementById('wheelCenterImg').style.display='none';
    document.getElementById('chancePct').style.display='block';
}

async function openTargetPicker(){
    if(isSpinning)return;
    if(!selectedGift){alert('Сначала выбери подарок для апгрейда');return;}
    var list=document.getElementById('targetList');
    list.innerHTML='<div style="text-align:center;padding:30px;color:rgba(255,255,255,.4)">Загрузка...</div>';
    document.getElementById('targetPickerOverlay').classList.add('show');
    try{
        var r=await fetch('/api/upgrade-possible-gifts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({user_id:userId,current_gift_id:selectedGift.id})});
        var d=await r.json();
        if(!d.success){list.innerHTML='<div style="text-align:center;padding:30px;color:var(--red)">'+d.error+'</div>';return;}
        possibleTargets=[];
        d.possible_gifts.forEach(function(g){
            if(g.value>selectedGift.value){
                var chance=Math.max(10,Math.min((selectedGift.value/g.value)*100,75));
                g.upgrade_chance=Math.round(chance*10)/10;
                possibleTargets.push(g);
            }
        });
        possibleTargets.sort(function(a,b){return a.value-b.value});
        renderTargetList();
    }catch(e){list.innerHTML='<div style="text-align:center;padding:30px;color:var(--red)">Ошибка загрузки</div>';}
}
function closeTargetPicker(){document.getElementById('targetPickerOverlay').classList.remove('show')}

function renderTargetList(){
    var list=document.getElementById('targetList');list.innerHTML='';
    if(possibleTargets.length===0){list.innerHTML='<div style="text-align:center;padding:30px;color:rgba(255,255,255,.4)">Нет доступных целей</div>';return;}
    possibleTargets.forEach(function(g){
        var div=document.createElement('div');div.className='target-item';
        div.innerHTML='<img src="'+g.image+'" alt=""><div class="target-item-info"><div class="target-item-name">'+g.name+'</div><div class="target-item-price"><img src="/static/img/ton.png" alt="">'+((g.value||0)/100).toFixed(2)+' TON</div></div><div class="target-item-chance">'+g.upgrade_chance+'%</div>';
        div.onclick=function(){selectTarget(g);closeTargetPicker();};
        list.appendChild(div);
    });
}

function selectTarget(g){
    targetGift=g;
    document.getElementById('rightCard').classList.add('has-gift');
    document.getElementById('rightGiftImg').src=g.image;
    document.getElementById('rightGiftName').textContent=g.name;
    document.getElementById('rightGiftValue').textContent=((g.value||0)/100).toFixed(2);
    document.getElementById('wheelCenterImg').src=g.image;
    document.getElementById('wheelCenterImg').style.display='block';
    document.getElementById('chancePct').style.display='none';
    updateWheel();
}

function updateWheel(){
    var btn=document.getElementById('upgradeBtn');
    var chancePct=document.getElementById('chancePct');

    if(!targetGift||!selectedGift){
        chancePct.textContent='0.00%';
        btn.disabled=true;
        return;
    }

    var chance=Math.max(10,Math.min((selectedGift.value/targetGift.value)*100,75));
    chance=Math.round(chance*10)/10;

    if(selectedGift.value<targetGift.value){
        btn.disabled=false;
    }else{
        btn.disabled=true;
    }
    btn.classList.remove('win','fail');
    document.getElementById('upgradeBtnText').textContent='Апгрейд';
}

async function doUpgrade(){
    if(isSpinning||!targetGift||!selectedGift)return;
    isSpinning=true;
    var btn=document.getElementById('upgradeBtn');
    btn.disabled=true;
    document.getElementById('upgradeBtnText').textContent='Крутим...';
    document.getElementById('resultSad').classList.remove('show');
    document.getElementById('resultHappy').classList.remove('show');
    document.getElementById('wheelGlow').classList.add('spinning');

    var displayChance=Math.max(10,Math.min((selectedGift.value/targetGift.value)*100,75));
    displayChance=Math.round(displayChance*10)/10;
    document.getElementById('wheelCenterImg').style.display='none';
    document.getElementById('chancePct').style.display='block';
    document.getElementById('chancePct').textContent=displayChance.toFixed(2)+'%';

    var pointerWrap=document.getElementById('pointerWrap');
    pointerWrap.style.transition='none';
    pointerWrap.style.transform='rotate(0deg)';

    try{
        var r=await fetch('/api/upgrade-multi',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({user_id:userId,inventory_ids:[selectedGift.id],target_gift_id:targetGift.fragment_slug||targetGift.id})});
        var d=await r.json();

        if(!d.success){
            document.getElementById('wheelGlow').classList.remove('spinning');
            alert(d.error||'Ошибка');resetAfterSpin();return;
        }

        var chance=d.chance;
        var greenAngle=(chance/100)*360;
        var landAngle;
        if(d.upgrade_success){
            // Land in green zone (0 to greenAngle)
            landAngle=Math.random()*greenAngle*0.8+greenAngle*0.1;
        }else{
            // Land in red zone (greenAngle to 360)
            var redSize=360-greenAngle;
            landAngle=greenAngle+Math.random()*redSize*0.8+redSize*0.1;
        }
        
        // Spin multiple full rotations plus landing angle
        var totalSpin=360*(4+Math.floor(Math.random()*3))+landAngle;
        var spinDuration=3000+Math.random()*500;
        
        // Animate using CSS transition
        pointerWrap.style.transition='transform '+spinDuration+'ms cubic-bezier(0.15, 0.7, 0.3, 1)';
        pointerWrap.style.transform='rotate('+totalSpin+'deg)';

        setTimeout(function(){
            document.getElementById('wheelGlow').classList.remove('spinning');
            showResult(d);
        }, spinDuration);
        
    }catch(e){
        document.getElementById('wheelGlow').classList.remove('spinning');
        pointerWrap.style.transform='rotate(0deg)';
        alert('Ошибка сети');resetAfterSpin();
    }
}

function showResult(d){
    var center=document.getElementById('wheelCenter');
    var btn=document.getElementById('upgradeBtn');
    document.getElementById('chancePct').style.display='none';
    if(d.upgrade_success){
        center.classList.add('flash-green');
        document.getElementById('resultHappy').classList.add('show');
        btn.classList.add('win');
        document.getElementById('upgradeBtnText').textContent='Победа!';
        launchConfetti();
    }else{
        center.classList.add('flash-red');
        document.getElementById('resultSad').classList.add('show');
        btn.classList.add('fail');
        document.getElementById('upgradeBtnText').textContent='Неудача';
    }
    setTimeout(function(){
        center.classList.remove('flash-red','flash-green');
        resetAfterSpin();loadInventory();loadTopBar();
    },3500);
}

function resetAfterSpin(){
    isSpinning=false;
    selectedGift=null;
    targetGift=null;
    document.getElementById('leftCard').classList.remove('has-gift');
    document.getElementById('rightCard').classList.remove('has-gift');
    document.getElementById('wheelCenterImg').style.display='none';
    document.getElementById('chancePct').style.display='block';
    document.getElementById('chancePct').textContent='0.00%';
    document.getElementById('resultSad').classList.remove('show');
    document.getElementById('resultHappy').classList.remove('show');
    var pointerWrap=document.getElementById('pointerWrap');
    pointerWrap.style.transition='none';
    pointerWrap.style.transform='rotate(0deg)';
    updateWheel();
}

function launchConfetti(){
    var canvas=document.getElementById('confettiCanvas');
    canvas.width=window.innerWidth;canvas.height=window.innerHeight;
    var ctx=canvas.getContext('2d');var particles=[];
    var colors=['#1EE44C','#06B6D4','#3B82F6','#00b4ff','#FDA100','#fff'];
    for(var i=0;i<120;i++){
        particles.push({x:canvas.width/2+(Math.random()-.5)*100,y:canvas.height/2,vx:(Math.random()-.5)*12,vy:-Math.random()*14-4,w:Math.random()*8+3,h:Math.random()*6+2,color:colors[Math.floor(Math.random()*colors.length)],rot:Math.random()*360,rv:(Math.random()-.5)*10,life:1});
    }
    function draw(){
        ctx.clearRect(0,0,canvas.width,canvas.height);var alive=false;
        particles.forEach(function(p){
            if(p.life<=0)return;alive=true;
            p.x+=p.vx;p.y+=p.vy;p.vy+=0.35;p.rot+=p.rv;p.life-=0.008;
            ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);
            ctx.globalAlpha=Math.max(0,p.life);ctx.fillStyle=p.color;
            ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();
        });
        if(alive)requestAnimationFrame(draw);else ctx.clearRect(0,0,canvas.width,canvas.height);
    }
    draw();
}

function openDeposit(){document.getElementById('depositOverlay').classList.add('show')}
function closeDeposit(){document.getElementById('depositOverlay').classList.remove('show')}

loadTopBar();
loadInventory();
</script>
</body>
</html>
